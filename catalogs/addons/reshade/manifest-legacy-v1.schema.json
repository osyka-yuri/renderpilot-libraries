{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renderpilot.app/schema/reshade_manifest.schema.json",
  "title": "Legacy ReShade host manifest",
  "description": "Standalone, tool-agnostic ReShade host sources retained for legacy RenoDX clients. Current applications consume addons/v1/reshade.json instead.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "nightly"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "stable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": {
          "$ref": "#/$defs/httpsUrl",
          "pattern": "^https://reshade\\.me/downloads/ReShade_Setup_\\d+\\.\\d+\\.\\d+_Addon\\.exe$"
        }
      }
    },
    "nightly": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url64", "url32"],
      "properties": {
        "url64": { "$ref": "#/$defs/httpsUrl" },
        "url32": { "$ref": "#/$defs/httpsUrl" }
      }
    }
  },
  "$defs": {
    "httpsUrl": { "type": "string", "format": "uri", "pattern": "^https://" }
  }
}
