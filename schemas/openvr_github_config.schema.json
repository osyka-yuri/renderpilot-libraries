{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osyka-yuri.github.io/renderpilot-libraries/schemas/openvr_github_config.schema.json",
  "title": "RenderPilot Valve OpenVR GitHub configuration",
  "type": "object",
  "required": [
    "schema_version",
    "repository",
    "expected_stable_releases",
    "require_signed_release_at_or_after",
    "architectures"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "repository": { "const": "ValveSoftware/openvr" },
    "expected_stable_releases": { "type": "integer", "minimum": 1 },
    "require_signed_release_at_or_after": {
      "description": "Unsigned artifacts are forbidden for releases published at or after this timestamp.",
      "type": "string",
      "format": "date-time"
    },
    "architectures": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": ["catalog_architecture", "repository_path"],
        "additionalProperties": false,
        "properties": {
          "catalog_architecture": { "enum": ["X64", "X86"] },
          "repository_path": {
            "enum": ["bin/win64/openvr_api.dll", "bin/win32/openvr_api.dll"]
          }
        }
      }
    }
  }
}
