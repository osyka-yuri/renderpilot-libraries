{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osyka-yuri.github.io/renderpilot-libraries/schemas/github_release_tree_config.schema.json",
  "title": "RenderPilot GitHub release-tree provider configuration",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "repository",
    "expected_stable_releases",
    "trusted_signer_subjects"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "profile": { "enum": ["amd_fidelityfx", "intel_xess", "openvr"] },
    "repository": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "expected_stable_releases": { "type": "integer", "minimum": 1 },
    "trusted_signer_subjects": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "require_valid_signature_at_or_after": {
      "description": "OpenVR only. Unsigned artifacts are forbidden for releases published at or after this timestamp.",
      "type": "string",
      "format": "date-time"
    }
  }
}
