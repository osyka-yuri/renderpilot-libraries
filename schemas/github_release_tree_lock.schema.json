{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://osyka-yuri.github.io/renderpilot-libraries/schemas/github_release_tree_lock.schema.json",
  "title": "RenderPilot immutable GitHub release-tree lock",
  "type": "object",
  "required": ["schema_version", "profile", "releases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": 1 },
    "profile": { "enum": ["amd_fidelityfx", "intel_xess", "openvr"] },
    "releases": {
      "type": "array",
      "items": { "$ref": "#/$defs/release" }
    }
  },
  "$defs": {
    "release": {
      "oneOf": [
        { "$ref": "#/$defs/importedRelease" },
        { "$ref": "#/$defs/excludedRelease" }
      ]
    },
    "releaseIdentity": {
      "type": "object",
      "required": [
        "release_id",
        "tag",
        "version",
        "label",
        "published_at",
        "tag_ref_sha",
        "commit_sha",
        "disposition"
      ],
      "properties": {
        "release_id": { "type": "integer", "minimum": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "version": { "$ref": "#/$defs/version" },
        "label": { "type": ["string", "null"] },
        "published_at": { "type": "string", "format": "date-time" },
        "tag_ref_sha": { "$ref": "#/$defs/sha1" },
        "commit_sha": { "$ref": "#/$defs/sha1" },
        "disposition": { "enum": ["imported", "excluded"] }
      }
    },
    "importedRelease": {
      "allOf": [
        { "$ref": "#/$defs/releaseIdentity" },
        {
          "type": "object",
          "required": ["artifacts", "legal_documents"],
          "additionalProperties": false,
          "properties": {
            "release_id": true,
            "tag": true,
            "version": true,
            "label": true,
            "published_at": true,
            "tag_ref_sha": true,
            "commit_sha": true,
            "disposition": { "const": "imported" },
            "artifacts": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/artifact" }
            },
            "legal_documents": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/legalDocument" }
            }
          }
        }
      ]
    },
    "excludedRelease": {
      "allOf": [
        { "$ref": "#/$defs/releaseIdentity" },
        {
          "type": "object",
          "required": ["exclusion_reason"],
          "additionalProperties": false,
          "properties": {
            "release_id": true,
            "tag": true,
            "version": true,
            "label": true,
            "published_at": true,
            "tag_ref_sha": true,
            "commit_sha": true,
            "disposition": { "const": "excluded" },
            "exclusion_reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "artifact": {
      "type": "object",
      "required": [
        "component",
        "architecture",
        "repository_path",
        "git_blob_sha1",
        "pe_version",
        "pe_named_exports",
        "dll_sha256",
        "dll_size_bytes",
        "signature",
        "r2"
      ],
      "additionalProperties": false,
      "properties": {
        "component": { "$ref": "#/$defs/id" },
        "architecture": { "enum": ["X64", "X86"] },
        "repository_path": { "$ref": "#/$defs/repositoryPath" },
        "git_blob_sha1": { "$ref": "#/$defs/sha1" },
        "pe_version": {
          "anyOf": [{ "$ref": "#/$defs/version" }, { "type": "null" }]
        },
        "pe_named_exports": {
          "type": "array",
          "maxItems": 16384,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "pattern": "^[ -~]+$"
          }
        },
        "dll_sha256": { "$ref": "#/$defs/sha256" },
        "dll_size_bytes": { "type": "integer", "minimum": 1 },
        "signature": { "$ref": "#/$defs/signature" },
        "r2": { "$ref": "#/$defs/r2" }
      }
    },
    "legalDocument": {
      "type": "object",
      "required": [
        "kind",
        "title",
        "format",
        "file_name",
        "repository_path",
        "git_blob_sha1",
        "sha256",
        "size_bytes",
        "object_key"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["license", "notice"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "format": { "enum": ["text", "pdf"] },
        "file_name": {
          "type": "string",
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9._-]+\\.(?:md|pdf|txt)$"
        },
        "repository_path": { "$ref": "#/$defs/repositoryPath" },
        "git_blob_sha1": { "$ref": "#/$defs/sha1" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "object_key": {
          "type": "string",
          "pattern": "^libraries/legal/sha256/[0-9a-f]{64}\\.(?:pdf|txt)$"
        }
      }
    },
    "signature": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status"],
          "additionalProperties": false,
          "properties": { "status": { "const": "unsigned" } }
        },
        {
          "type": "object",
          "required": ["status", "subject", "thumbprint", "signed_at"],
          "additionalProperties": false,
          "properties": {
            "status": { "const": "signed" },
            "subject": { "type": "string", "minLength": 1 },
            "thumbprint": {
              "type": "string",
              "pattern": "^[A-F0-9]{40,64}$"
            },
            "signed_at": {
              "type": ["string", "null"],
              "format": "date-time"
            }
          }
        }
      ]
    },
    "r2": {
      "type": "object",
      "required": ["object_key", "zst_sha256", "zst_size_bytes", "compression_level"],
      "additionalProperties": false,
      "properties": {
        "object_key": {
          "type": "string",
          "pattern": "^libraries/blobs/sha256/[0-9a-f]{64}\\.dll\\.zst$"
        },
        "zst_sha256": { "$ref": "#/$defs/sha256" },
        "zst_size_bytes": { "type": "integer", "minimum": 1 },
        "compression_level": { "type": "integer", "minimum": 1, "maximum": 22 }
      }
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\).+$"
    },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
    "sha1": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "version": {
      "type": "string",
      "pattern": "^(?:0|[1-9]\\d*)(?:\\.(?:0|[1-9]\\d*))*$"
    }
  }
}
