{
  "name": "renderpilot-libraries-tools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Validation and Cloudflare R2 publishing tooling for the RenderPilot libraries catalog.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "check": "pnpm run format:check && pnpm run validate && pnpm run validate:microsoft && pnpm run validate:openvr && pnpm run check:all-generated && pnpm run test:renodx && pnpm run test:luma && pnpm run test:scripts && pnpm run sync:renodx-wiki:check && pnpm run sync:luma-wiki:check && pnpm run check:slugs && pnpm run check:luma-assets && pnpm run check:luma-payload-layout",
    "check:offline": "pnpm run format:check && pnpm run validate && pnpm run validate:microsoft && pnpm run validate:openvr && pnpm run check:all-generated && pnpm run test:renodx && pnpm run test:luma && pnpm run test:scripts",
    "validate": "node scripts/validate.mjs",
    "validate:microsoft": "node scripts/validate-microsoft-nuget.mjs",
    "validate:openvr": "node scripts/validate-openvr-github.mjs",
    "check:slugs": "node scripts/check-renodx-slugs.mjs",
    "check:luma-assets": "node scripts/check-luma-assets.mjs",
    "check:luma-payload-layout": "node scripts/check-luma-payload-layout.mjs",
    "check:reshade-generated": "node scripts/generate-reshade-manifest.mjs --check",
    "check:renodx-generated": "node catalogs/addons/renodx/generate-manifest.mjs --check",
    "check:luma-generated": "node catalogs/addons/luma/generate-manifest.mjs --check",
    "enrich:exe": "node scripts/enrich-exe.mjs",
    "generate:reshade": "node scripts/generate-reshade-manifest.mjs",
    "generate:renodx": "node catalogs/addons/renodx/generate-manifest.mjs",
    "generate:luma": "node catalogs/addons/luma/generate-manifest.mjs",
    "sync:renodx-wiki": "node scripts/sync-renodx-wiki.mjs && pnpm run generate:renodx",
    "sync:renodx-wiki:check": "node scripts/sync-renodx-wiki.mjs --check",
    "sync:luma-wiki": "node scripts/sync-luma-wiki.mjs && pnpm run generate:luma",
    "sync:luma-wiki:check": "node scripts/sync-luma-wiki.mjs --check",
    "match-pending:renodx": "node scripts/match-pending.mjs --tool=renodx",
    "match-pending:luma": "node scripts/match-pending.mjs --tool=luma",
    "test:renodx": "node --test \"catalogs/addons/renodx/test/*.test.mjs\"",
    "test:luma": "node --test \"catalogs/addons/luma/test/*.test.mjs\"",
    "test:scripts": "node --test \"scripts/test/*.test.mjs\"",
    "test:authenticode": "pwsh -NoLogo -NoProfile -File scripts/test/authenticode-timestamp.test.ps1 && pwsh -NoLogo -NoProfile -File scripts/test/pe-inspector.test.ps1",
    "check:published-json": "node scripts/libraries.mjs audit-published",
    "check:upstream-health": "node scripts/check-upstream-health.mjs --suite=all",
    "check:wiki-drift": "node scripts/check-wiki-drift.mjs",
    "check:wiki-drift:notify": "node scripts/check-wiki-drift.mjs --notify",
    "check:all-generated": "pnpm run libraries:check && pnpm run check:reshade-generated && pnpm run check:renodx-generated && pnpm run check:luma-generated",
    "libraries:generate": "node scripts/libraries.mjs generate",
    "libraries:check": "node scripts/libraries.mjs generate --check",
    "refresh:microsoft:check": "node scripts/libraries.mjs refresh microsoft --check",
    "refresh:microsoft:write": "node scripts/libraries.mjs refresh microsoft --write",
    "materialize:microsoft": "node scripts/libraries.mjs refresh microsoft --materialize-locked",
    "backfill:microsoft-signatures": "node scripts/libraries.mjs refresh microsoft --backfill-signatures",
    "refresh:openvr:check": "node scripts/libraries.mjs refresh openvr --check",
    "refresh:openvr:write": "node scripts/libraries.mjs refresh openvr --write",
    "materialize:openvr": "node scripts/libraries.mjs refresh openvr --materialize-locked",
    "backfill:openvr-signatures": "node scripts/libraries.mjs refresh openvr --backfill-signatures",
    "refresh:reshade:check": "node scripts/refresh-reshade-stable.mjs --check",
    "refresh:reshade:write": "node scripts/refresh-reshade-stable.mjs --write",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "node scripts/libraries.mjs publish",
    "publish:binaries": "node scripts/libraries.mjs publish --binary-only",
    "publish:json": "node scripts/libraries.mjs publish --json-only",
    "publish:json:dry-run": "node scripts/libraries.mjs publish --json-only --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "prettier": "^3.9.5"
  }
}
