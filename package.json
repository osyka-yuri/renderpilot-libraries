{
  "name": "renderpilot-libraries-tools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "description": "Validation and Cloudflare R2 publishing tooling for the RenderPilot libraries catalog.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "pnpm run format:check && pnpm run validate && pnpm run check:renodx-generated && pnpm run test:renodx && pnpm run check:slugs",
    "validate": "node scripts/validate.mjs",
    "check:slugs": "node scripts/check-renodx-slugs.mjs",
    "check:renodx-generated": "node renodx_library_manifest/generate-manifest.mjs --check",
    "enrich:renodx-exe": "node renodx_library_manifest/enrich-exe.mjs",
    "generate:renodx": "node renodx_library_manifest/generate-manifest.mjs",
    "sync:wiki": "node scripts/sync-wiki.mjs && pnpm run generate:renodx",
    "test:renodx": "node --test \"renodx_library_manifest/test/*.test.mjs\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "node scripts/publish-r2.mjs",
    "publish:json": "node scripts/publish-r2.mjs --json-only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "prettier": "^3.7.4"
  }
}
