{
  "name": "renderpilot-libraries-tools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Validation and Cloudflare R2 publishing tooling for the RenderPilot libraries catalog.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "pnpm run format:check && pnpm run validate && pnpm run check:reshade-generated && pnpm run check:renodx-generated && pnpm run check:luma-generated && pnpm run test:renodx && pnpm run test:luma && pnpm run test:scripts && pnpm run check:slugs && pnpm run check:luma-assets",
    "validate": "node scripts/validate.mjs",
    "check:slugs": "node scripts/check-renodx-slugs.mjs",
    "check:luma-assets": "node scripts/check-luma-assets.mjs",
    "check:reshade-generated": "node scripts/generate-reshade-manifest.mjs --check",
    "check:renodx-generated": "node renodx_library_manifest/generate-manifest.mjs --check",
    "check:luma-generated": "node luma_library_manifest/generate-manifest.mjs --check",
    "enrich:exe": "node scripts/enrich-exe.mjs",
    "generate:reshade": "node scripts/generate-reshade-manifest.mjs",
    "generate:renodx": "node renodx_library_manifest/generate-manifest.mjs",
    "generate:luma": "node luma_library_manifest/generate-manifest.mjs",
    "sync:wiki": "node scripts/sync-wiki.mjs && pnpm run generate:renodx",
    "match-pending:renodx": "node scripts/match-pending.mjs --tool=renodx",
    "match-pending:luma": "node scripts/match-pending.mjs --tool=luma",
    "test:renodx": "node --test \"renodx_library_manifest/test/*.test.mjs\"",
    "test:luma": "node --test \"luma_library_manifest/test/*.test.mjs\"",
    "test:scripts": "node --test \"scripts/test/*.test.mjs\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish": "node scripts/publish-r2.mjs",
    "publish:json": "node scripts/publish-r2.mjs --json-only"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
